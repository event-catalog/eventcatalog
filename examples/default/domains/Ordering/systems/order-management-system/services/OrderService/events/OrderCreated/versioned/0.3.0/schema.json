{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrderCreated",
  "description": "Published when a new order has been created",
  "type": "object",
  "properties": {
    "orderId": {
      "type": "string",
      "format": "uuid"
    },
    "customerId": {
      "type": "string",
      "format": "uuid"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["orderId", "customerId", "createdAt"]
}
