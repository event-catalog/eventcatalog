{
  "rewrites": [
    {
      "source": "/docs",
      "destination": "https://compass-docs-liart.vercel.app/"
    },
    {
      "source": "/docs/(.*)",
      "destination": "https://compass-docs-liart.vercel.app/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
