{
  "rewrites": [
    {
      "source": "/docs",
      "destination": "https://compass-docs-liart.vercel.app/"
    },
    {
      "source": "/docs/:path*",
      "destination": "https://compass-docs-liart.vercel.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
