---
import { getCollection } from 'astro:content';
import VerticalSideBarLayout from '@layouts/VerticalSideBarLayout.astro';

const schemas = await getCollection('schemas');

const schemasByCollection = schemas.reduce<Record<string, typeof schemas>>((acc, schema) => {
  const collection = schema.data.message.collection;
  acc[collection] = acc[collection] || [];
  acc[collection].push(schema);
  return acc;
}, {});

const previewContent = (content?: string) => {
  if (!content) return 'No payload loaded';
  const compact = content.trim();
  return compact.length > 500 ? `${compact.slice(0, 500)}...` : compact;
};
---

<VerticalSideBarLayout title="Schema Collection Debug - EventCatalog" showNestedSideBar={false}>
  <main class="min-h-[calc(100vh-60px)] bg-[rgb(var(--ec-page-bg))]">
    <div class="mx-auto max-w-7xl px-6 py-8">
      <div class="mb-8">
        <p class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--ec-page-text-muted))]">Debug</p>
        <h1 class="mt-2 text-2xl font-semibold text-[rgb(var(--ec-page-text))]">Schema Collection</h1>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-[rgb(var(--ec-page-text-muted))]">
          Generated schema entries from message schema references. Total schemas: {schemas.length}
        </p>
      </div>

      {
        schemas.length === 0 ? (
          <div class="border border-[rgb(var(--ec-page-border))] bg-[rgb(var(--ec-card-bg,var(--ec-page-bg)))] px-4 py-6 text-sm text-[rgb(var(--ec-page-text-muted))]">
            No schema collection entries were generated.
          </div>
        ) : (
          <div class="space-y-8">
            {Object.entries(schemasByCollection).map(([collection, collectionSchemas]) => (
              <section>
                <div class="mb-3 flex items-baseline justify-between gap-4">
                  <h2 class="text-lg font-semibold capitalize text-[rgb(var(--ec-page-text))]">{collection}</h2>
                  <span class="text-xs text-[rgb(var(--ec-page-text-muted))]">{collectionSchemas.length} schemas</span>
                </div>

                <div class="overflow-hidden border border-[rgb(var(--ec-page-border))] bg-[rgb(var(--ec-card-bg,var(--ec-page-bg)))]">
                  <table class="min-w-full divide-y divide-[rgb(var(--ec-page-border))] text-left text-sm">
                    <thead class="bg-[rgb(var(--ec-content-hover)/0.45)] text-xs uppercase text-[rgb(var(--ec-page-text-muted))]">
                      <tr>
                        <th class="px-4 py-3 font-semibold">Schema</th>
                        <th class="px-4 py-3 font-semibold">Message</th>
                        <th class="px-4 py-3 font-semibold">Owners</th>
                        <th class="px-4 py-3 font-semibold">Format</th>
                        <th class="px-4 py-3 font-semibold">Environments</th>
                        <th class="px-4 py-3 font-semibold">Source</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-[rgb(var(--ec-page-border))]">
                      {collectionSchemas.map((schema) => (
                        <tr>
                          <td class="px-4 py-3 align-top">
                            <div class="font-mono text-xs font-semibold text-[rgb(var(--ec-page-text))]">{schema.data.id}</div>
                            <div class="mt-1 text-xs text-[rgb(var(--ec-page-text-muted))]">
                              {schema.data.name}
                              {schema.data.default ? ' (default)' : ''}
                            </div>
                          </td>
                          <td class="px-4 py-3 align-top">
                            <div class="font-medium text-[rgb(var(--ec-page-text))]">
                              {schema.data.message.name || schema.data.message.id}
                            </div>
                            <div class="mt-1 text-xs text-[rgb(var(--ec-page-text-muted))]">
                              {schema.data.message.id} v{schema.data.message.version}
                              {schema.data.latest ? ' (latest)' : ''}
                            </div>
                            {schema.data.message.summary && (
                              <div class="mt-1 max-w-sm text-xs text-[rgb(var(--ec-page-text-muted))]">
                                {schema.data.message.summary}
                              </div>
                            )}
                          </td>
                          <td class="px-4 py-3 align-top text-[rgb(var(--ec-page-text))]">
                            {schema.data.message.owners?.length ? schema.data.message.owners.join(', ') : 'none'}
                          </td>
                          <td class="px-4 py-3 align-top text-[rgb(var(--ec-page-text))]">{schema.data.format}</td>
                          <td class="px-4 py-3 align-top text-[rgb(var(--ec-page-text))]">
                            {schema.data.environments?.length ? schema.data.environments.join(', ') : 'all'}
                          </td>
                          <td class="px-4 py-3 align-top">
                            <div class="text-[rgb(var(--ec-page-text))]">{schema.data.source.provider}</div>
                            <div class="mt-1 max-w-xs truncate font-mono text-xs text-[rgb(var(--ec-page-text-muted))]">
                              {schema.data.filePath || schema.data.source.path || 'unknown'}
                            </div>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>

                <div class="mt-4 space-y-3">
                  {collectionSchemas.map((schema) => (
                    <details class="border border-[rgb(var(--ec-page-border))] bg-[rgb(var(--ec-card-bg,var(--ec-page-bg)))]">
                      <summary class="cursor-pointer px-4 py-3 text-sm font-medium text-[rgb(var(--ec-page-text))]">
                        Payload preview: {schema.data.id}
                      </summary>
                      <pre class="max-h-80 overflow-auto border-t border-[rgb(var(--ec-page-border))] bg-[rgb(var(--ec-content-hover)/0.25)] p-4 text-xs leading-5 text-[rgb(var(--ec-page-text))]">
                        {previewContent(schema.data.content)}
                      </pre>
                    </details>
                  ))}
                </div>
              </section>
            ))}
          </div>
        )
      }
    </div>
  </main>
</VerticalSideBarLayout>
