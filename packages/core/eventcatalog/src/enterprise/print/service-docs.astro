                      <>
                        <div class="h-[3px] mt-3" />
                        <div class="h-[3px] bg-slate-50 rounded-full w-2/5 border border-slate-100" />
                        <div class="h-[3px] bg-slate-50 rounded-full w-full border border-slate-100" />
