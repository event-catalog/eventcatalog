            >
              <div class="shrink-0">
                {signal.status === 'good' ? (
                  <div class="w-7 h-7 rounded-full bg-green-50 border border-green-200 flex items-center justify-center">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
