---
interface Props {
  title: string;
  sidebar?: boolean;
  description?: string;
  showNestedSideBar?: boolean;
  showHeader?: boolean;
  // When true, the main content uses a reduced horizontal padding instead of the
  // default 5rem. Used by wide pages such as the custom landing page.
  reducedContentPadding?: boolean;
}

import * as LucideIcons from 'lucide-react';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import SideNav from '../components/SideNav/SideNav.astro';
import SearchDataLoader from '../components/Search/SearchDataLoader.astro';
import config from '@config';
import { getCollection } from 'astro:content';
import '@fontsource/inter';
import '@fontsource/inter/400.css'; // Specify weight
import '@fontsource/inter/700.css'; // Specify weight

// Tailwind CSS v4 (CSS-first config)
import '../styles/tailwind.css';

// Theme CSS variables (must load before user styles)
import '../styles/theme.css';

// Theme files - imported so they're available, applied via data-catalog-theme attribute
import '../styles/themes/ocean.css';
import '../styles/themes/sapphire.css';
import '../styles/themes/sunset.css';
import '../styles/themes/forest.css';

import { ClientRouter } from 'astro:transitions';

import { getCommands } from '@utils/collections/commands';
import { getDomains } from '@utils/collections/domains';
import { getSystems } from '@utils/collections/systems';
import { getEvents } from '@utils/collections/events';
import { getServices } from '@utils/collections/services';
import { getAgents } from '@utils/collections/agents';
import { getFlows } from '@utils/collections/flows';
import { getAdrs } from '@utils/collections/adrs';
import { getContainers } from '@utils/collections/containers';
import { getDataProducts } from '@utils/collections/data-products';
import { isCollectionVisibleInCatalog } from '@eventcatalog';
import { buildUrl } from '@utils/url-builder';
import { getQueries } from '@utils/collections/queries';
import { getFirstNavigationPage } from '@enterprise/custom-documentation/utils/custom-docs';

import { isEmbedEnabled, isCustomStylesEnabled, isCustomDocsEnabled, isSSR } from '@utils/feature';

const customDocs = await getCollection('customPages');
const firstCustomDocsPage = isCustomDocsEnabled() && customDocs.length > 0 ? await getFirstNavigationPage() : null;

let events: any[] = [];
let commands: any[] = [];
let queries: any[] = [];
let services: any[] = [];
let agents: any[] = [];
let adrs: any[] = [];
let domains: any[] = [];
let systems: any[] = [];
let flows: any[] = [];
let containers: any[] = [];
let dataProducts: any[] = [];

[events, commands, queries, services, agents, adrs, domains, systems, flows, containers, dataProducts] = await Promise.all([
  getEvents({ getAllVersions: false, hydrateServices: false }),
  getCommands({ getAllVersions: false, hydrateServices: false }),
  getQueries({ getAllVersions: false, hydrateServices: false }),
  getServices({ getAllVersions: false }),
  getAgents({ getAllVersions: false }),
  getAdrs({ getAllVersions: false }),
  getDomains({ getAllVersions: false }),
  getSystems({ getAllVersions: false }),
  getFlows({ getAllVersions: false }),
  getContainers({ getAllVersions: false }),
  getDataProducts({ getAllVersions: false }),
]);

// Try and load any custom styles if they exist
if (isCustomStylesEnabled()) {
  try {
    await import('../../eventcatalog.styles.css');
  } catch (error) {}
}

const currentPath = Astro.url.pathname;

const getDefaultUrl = (route: string, defaultValue: string) => {
  if (route === 'docs/custom') {
    return firstCustomDocsPage ? buildUrl(`/${route}/${firstCustomDocsPage.slug}`) : buildUrl(defaultValue);
  }

  const collections = [
    { data: domains, key: 'domains' },
    { data: services, key: 'services' },
    { data: agents, key: 'agents' },
    { data: events, key: 'events' },
    { data: commands, key: 'commands' },
    { data: queries, key: 'queries' },
    { data: flows, key: 'flows' },
  ];

  for (const { data, key } of collections) {
    if (data.length > 0 && isCollectionVisibleInCatalog(key)) {
      // find the first item that has visualiser set to true
      const item = data.find((item) => item.data.visualiser !== false);
      if (item) {
        return buildUrl(`/${route}/${key}/${item.data.id}/${item.data.latestVersion}`);
      } else {
        continue;
      }
    }
  }

  return buildUrl(defaultValue);
};

const internalServices = services.filter((service) => !service.data.externalSystem);
const externalSystems = services.filter((service) => service.data.externalSystem);
const discoverTargets = [
  { id: '/discover/domains', href: buildUrl('/discover/domains'), count: domains.length },
  { id: '/discover/systems', href: buildUrl('/discover/systems'), count: systems.length },
  {
    id: '/discover/services',
    href: buildUrl('/discover/services'),
    count: internalServices.length,
  },
  {
    id: '/discover/external-systems',
    href: buildUrl('/discover/external-systems'),
    count: externalSystems.length,
  },
  { id: '/discover/agents', href: buildUrl('/discover/agents'), count: agents.length },
  { id: '/discover/adrs', href: buildUrl('/discover/adrs'), count: adrs.length },
  {
    id: '/discover/data-products',
    href: buildUrl('/discover/data-products'),
    count: dataProducts.length,
  },
  { id: '/discover/containers', href: buildUrl('/discover/containers'), count: containers.length },
  { id: '/discover/events', href: buildUrl('/discover/events'), count: events.length },
  { id: '/discover/commands', href: buildUrl('/discover/commands'), count: commands.length },
  { id: '/discover/queries', href: buildUrl('/discover/queries'), count: queries.length },
  { id: '/discover/flows', href: buildUrl('/discover/flows'), count: flows.length },
];
const defaultDiscoverTarget = discoverTargets.find((target) => target.count > 0);

type NavigationItemConfig = {
  id: string;
  label?: string;
  icon?: string;
  href?: string;
  visible?: boolean;
  match?: string | string[];
};

type NavigationGroupConfig = {
  id: string;
  label?: string;
  visible?: boolean;
  position?: 'top' | 'bottom';
  items?: NavigationItemConfig[];
};

type VerticalNavigationItem = Required<Pick<NavigationItemConfig, 'id' | 'label' | 'href'>> & {
  icon: string;
  current: boolean;
  matchId: string;
  match?: string | string[];
  target?: string;
  rel?: string;
  Icon: any;
};

const toPascalCase = (value: string) =>
  value
    .split(/[-_\s]+/)
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join('');

const resolveLucideIcon = (icon?: string) => {
  if (!icon) return LucideIcons.Circle;

  const icons = LucideIcons as unknown as Record<string, any>;
  return (
    icons[icon] || icons[`${icon}Icon`] || icons[toPascalCase(icon)] || icons[`${toPascalCase(icon)}Icon`] || LucideIcons.Circle
  );
};

const normalizeNavigationHref = (href: string) => {
  if (/^(https?:)?\/\//.test(href) || href.startsWith('mailto:') || href.startsWith('#')) {
    return href;
  }

  return buildUrl(href);
};

const isExternalNavigationHref = (href: string) => /^https?:\/\//.test(href);

const normalizeNavigationMatch = (match?: string | string[]) => {
  if (!match) return undefined;

  const normalizeMatch = (value: string) => (isExternalNavigationHref(value) ? value : buildUrl(value, true));
  return Array.isArray(match) ? match.map(normalizeMatch) : normalizeMatch(match);
};

const navigationBuiltinAliases: Record<string, string> = {
  home: '/',
  docs: '/docs/custom',
  catalog: '/discover',
  schemas: '/schemas/explorer',
  'schema-insights': '/schemas/fields',
  teams: '/directory/teams',
  users: '/directory/users',
  settings: '/settings/general',
  studio: '/studio',
};

const builtinNavigationItems: Record<string, Omit<VerticalNavigationItem, 'current' | 'Icon'>> = {
  '/': {
    id: '/',
    matchId: '/',
    label: 'Home',
    icon: 'House',
    href: buildUrl(config.landingPage || '/'),
  },
  '/docs/custom': {
    id: '/docs/custom',
    matchId: '/docs/custom',
    label: 'Docs',
    icon: 'FileText',
    href: getDefaultUrl('docs/custom', '/docs/custom'),
  },
  '/studio': {
    id: '/studio',
    matchId: '/studio',
    label: 'EventCatalog Studio',
    icon: 'SquareDashedMousePointer',
    href: buildUrl('/studio'),
  },
  '/discover': {
    id: '/discover',
    matchId: '/discover',
    label: 'Catalog',
    icon: 'TableProperties',
    href: defaultDiscoverTarget?.href ?? buildUrl('/discover/domains'),
  },
  '/schemas/explorer': {
    id: '/schemas/explorer',
    matchId: '/schemas/explorer',
    label: 'Schemas & APIs',
    icon: 'FileCode',
    href: buildUrl('/schemas/explorer'),
  },
  '/schemas/fields': {
    id: '/schemas/fields',
    matchId: '/schemas/fields',
    label: 'Schema Insights',
    icon: 'Waypoints',
    href: buildUrl('/schemas/fields'),
  },
  '/directory/teams': {
    id: '/directory/teams',
    matchId: '/directory/teams',
    label: 'Teams',
    icon: 'UsersRound',
    href: buildUrl('/directory/teams'),
  },
  '/directory/users': {
    id: '/directory/users',
    matchId: '/directory/users',
    label: 'Users',
    icon: 'UserRound',
    href: buildUrl('/directory/users'),
  },
  '/settings/general': {
    id: '/settings/general',
    matchId: '/settings/general',
    label: 'Settings',
    icon: 'Settings',
    href: buildUrl('/settings/general'),
  },
};

const defaultNavigationGroups: NavigationGroupConfig[] = [
  {
    id: 'main',
    items: [{ id: '/' }, { id: '/docs/custom', visible: isCustomDocsEnabled() && customDocs.length > 0 }],
  },
  {
    id: 'browse',
    label: 'Browse',
    items: [
      { id: '/discover', visible: Boolean(defaultDiscoverTarget) },
      { id: '/schemas/explorer' },
      { id: '/schemas/fields', visible: isSSR() },
    ],
  },
  {
    id: 'organization',
    label: 'Organization',
    items: [{ id: '/directory/teams' }, { id: '/directory/users' }],
  },
  {
    id: 'settings',
    position: 'bottom',
    items: [{ id: '/settings/general' }],
  },
];

const isNavigationItemCurrent = (item: Pick<VerticalNavigationItem, 'href' | 'matchId' | 'match'>, pathname: string) => {
  const matchId = item.matchId;

  if (matchId === '/') {
    const itemPath = new URL(item.href, Astro.url.origin).pathname;
    return (
      pathname === itemPath ||
      (pathname.includes('/docs') && !pathname.includes('/docs/custom')) ||
      pathname.includes('/architecture/') ||
      pathname.includes('/visualiser') ||
      (pathname.includes('/schemas') && !pathname.includes('/schemas/explorer') && !pathname.includes('/schemas/fields'))
    );
  }

  if (matchId === '/schemas/explorer') {
    return pathname.includes('/schemas/explorer') && !pathname.includes('/schemas/fields');
  }

  if (matchId === '/schemas/fields') {
    return pathname.includes('/schemas/fields');
  }

  if (matchId === '/discover') {
    return pathname === buildUrl('/discover', true) || pathname.endsWith('/discover') || pathname.includes('/discover/');
  }

  if (matchId === '/studio') {
    return pathname.includes('/studio');
  }

  if (matchId === '/docs/custom') {
    return pathname.includes('/docs/custom');
  }

  if (matchId === '/settings/general') {
    return pathname.startsWith(buildUrl('/settings', true));
  }

  const configuredMatches = Array.isArray(item.match) ? item.match : item.match ? [item.match] : [];
  if (configuredMatches.length > 0) {
    return configuredMatches.some((match) => {
      if (isExternalNavigationHref(match)) return false;

      return pathname === buildUrl(match, true) || pathname.startsWith(buildUrl(match, true));
    });
  }

  if (isExternalNavigationHref(item.href)) return false;

  const itemPath = new URL(item.href, Astro.url.origin).pathname;
  return pathname === itemPath;
};

const resolveNavigationItem = (item: NavigationItemConfig): VerticalNavigationItem | null => {
  if (item.visible === false) return null;

  const builtinId = navigationBuiltinAliases[item.id] || item.id;
  const builtin = builtinNavigationItems[builtinId];
  const href = item.href ? normalizeNavigationHref(item.href) : builtin?.href;

  if (!href) return null;

  const resolvedItem = {
    id: item.id,
    matchId: builtin?.matchId || item.id,
    label: item.label || builtin?.label || item.id,
    icon: item.icon || builtin?.icon || 'Circle',
    href,
    match: item.match,
  };

  return {
    ...resolvedItem,
    current: isNavigationItemCurrent(resolvedItem, currentPath),
    target: isExternalNavigationHref(href) ? '_blank' : undefined,
    rel: isExternalNavigationHref(href) ? 'noopener noreferrer' : undefined,
    Icon: resolveLucideIcon(resolvedItem.icon),
  };
};

const resolveNavigationGroups = (groups: NavigationGroupConfig[]) =>
  groups
    .filter((group) => group.visible !== false)
    .map((group) => ({
      id: group.id,
      label: group.label,
      position: group.position || 'top',
      items: (group.items || []).map(resolveNavigationItem).filter((item): item is VerticalNavigationItem => Boolean(item)),
    }))
    .filter((group) => group.items.length > 0);

const navigationGroups = resolveNavigationGroups(
  Array.isArray(config.navigation?.groups) ? (config.navigation.groups as NavigationGroupConfig[]) : defaultNavigationGroups
);
const topNavigationGroups = navigationGroups.filter((group) => group.position !== 'bottom');
const bottomNavigationGroups = navigationGroups.filter((group) => group.position === 'bottom');
const clientNavigationItems = navigationGroups.flatMap((group) =>
  group.items.map(({ id, href, matchId, match }) => ({
    id,
    href,
    matchId,
    match: normalizeNavigationMatch(match),
  }))
);
const { title, description, showNestedSideBar = true, showHeader = true, reducedContentPadding = false } = Astro.props;

const canPageBeEmbedded = isEmbedEnabled();
const verticalNavAutoCollapsePaths = [buildUrl('/discover', true), buildUrl('/docs', true)];
---

<BaseLayout title={`EventCatalog | ${title}`} description={description} ogTitle={title}>
  <Fragment slot="head">
    <script is:inline define:vars={{ verticalNavAutoCollapsePaths }}>
      (() => {
        const verticalNavStorageKey = 'eventcatalog-vertical-nav-collapsed';
        const routeShouldAutoCollapseVerticalNav = (pathname) =>
          verticalNavAutoCollapsePaths.some((path) => pathname === path || pathname.startsWith(`${path}/`));

        try {
          const shouldAutoCollapse = routeShouldAutoCollapseVerticalNav(window.location.pathname);
          if (shouldAutoCollapse) {
            localStorage.setItem(verticalNavStorageKey, 'true');
          }

          const savedState = localStorage.getItem(verticalNavStorageKey);
          const isCollapsed = shouldAutoCollapse ? true : savedState === null ? true : savedState === 'true';
          document.documentElement.setAttribute('data-vertical-nav-collapsed', isCollapsed ? 'true' : 'false');
        } catch (error) {
          document.documentElement.setAttribute('data-vertical-nav-collapsed', 'true');
        }
      })();
    </script>
    <style is:global>
      :root {
        --ec-vertical-nav-width: 14rem;
      }

      :root[data-vertical-nav-collapsed='true'] {
        --ec-vertical-nav-width: 3rem;
      }

      html,
      body {
        background-color: rgb(var(--ec-page-bg));
      }

      body {
        min-height: 100vh;
        min-height: 100dvh;
      }

      #eventcatalog-application {
        min-height: 100vh;
        min-height: 100dvh;
        background-color: rgb(var(--ec-page-bg));
        --ec-sidebar-panel-width: 17rem;
        display: flex;
        flex-direction: column;
      }

      .app-content-wrapper {
        --ec-app-content-padding-left: 5rem;
        --ec-app-content-padding-right: 5rem;
        margin-left: auto;
        margin-right: auto;
        padding-left: var(--ec-app-content-padding-left);
        padding-right: var(--ec-app-content-padding-right);
      }
      .app-content-wrapper--reduced-padding {
        --ec-app-content-padding-left: 2rem;
        --ec-app-content-padding-right: 2rem;
      }
      .app-shell {
        min-height: calc(100vh - 4rem);
        flex: 1;
      }
      .app-shell--rail-only {
        margin-left: var(--ec-vertical-nav-width);
      }
      .app-shell--with-sidebar {
        margin-left: calc(var(--ec-vertical-nav-width) + var(--ec-sidebar-panel-width));
      }
      .vertical-nav-rail {
        width: var(--ec-vertical-nav-width);
        border-right: 1px solid rgb(var(--ec-page-border));
        background-color: rgb(var(--ec-page-bg));
        box-shadow: 0 24px 44px -34px rgb(var(--ec-page-text) / 0.28);
        overflow: hidden;
      }
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail .nav-brand-text,
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail .nav-item-label,
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail .rail-section-label,
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail .nav-count-pill,
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail .nav-label,
      .vertical-nav-rail[data-collapsed='true'] .nav-brand-text,
      .vertical-nav-rail[data-collapsed='true'] .nav-item-label,
      .vertical-nav-rail[data-collapsed='true'] .rail-section-label,
      .vertical-nav-rail[data-collapsed='true'] .nav-count-pill,
      .vertical-nav-rail[data-collapsed='true'] .nav-label {
        display: none;
      }
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail .nav-brand-link,
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail [data-role='nav-item'],
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail .nav-secondary-item,
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail #vertical-nav-toggle,
      .vertical-nav-rail[data-collapsed='true'] .nav-brand-link,
      .vertical-nav-rail[data-collapsed='true'] [data-role='nav-item'],
      .vertical-nav-rail[data-collapsed='true'] .nav-secondary-item,
      .vertical-nav-rail[data-collapsed='true'] #vertical-nav-toggle {
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        padding: 0;
      }
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail .nav-brand-link,
      .vertical-nav-rail[data-collapsed='true'] .nav-brand-link {
        padding-left: 0;
        padding-right: 0;
      }
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail nav,
      .vertical-nav-rail[data-collapsed='true'] nav {
        align-items: center;
        gap: 0.75rem;
        padding-left: 0.25rem;
        padding-right: 0.25rem;
      }
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail .rail-divider,
      .vertical-nav-rail[data-collapsed='true'] .rail-divider {
        display: none;
      }
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail nav > .mt-auto,
      .vertical-nav-rail[data-collapsed='true'] nav > .mt-auto {
        margin-top: auto !important;
        padding-top: 0;
      }
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail nav + div,
      .vertical-nav-rail[data-collapsed='true'] nav + div {
        border-top: 0;
        display: flex;
        justify-content: center;
        padding: 0.75rem 0.25rem;
      }
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail .nav-premium-icon,
      .vertical-nav-rail[data-collapsed='true'] .nav-premium-icon {
        margin-left: 0;
      }
      :root[data-vertical-nav-collapsed='true'] .vertical-nav-rail .nav-collapse-icon,
      .vertical-nav-rail[data-collapsed='true'] .nav-collapse-icon {
        transform: rotate(180deg);
      }
      .sidebar-panel {
        width: var(--ec-sidebar-panel-width);
        min-width: var(--ec-sidebar-panel-width);
        height: 100vh;
        border-right: 1px solid rgb(var(--ec-content-border));
        background: rgb(var(--ec-rail-bg));
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        left: var(--ec-vertical-nav-width);
        z-index: 20;
        overflow-y: auto;
      }
      .content-panel {
        min-width: 0;
        flex: 1;
        min-height: calc(100vh - 4rem);
      }
      .sidebar-transition {
        transition-property: width, transform;
        transition-duration: 300ms;
        transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
      }
      .tooltip {
        visibility: hidden;
        position: absolute;
      }
      .has-tooltip:hover .tooltip {
        visibility: visible;
        z-index: 100;
      }

      /* Hide anchor link by default */
      .anchor-link {
        display: inline-block;
        width: 1em;
        height: 1em;
        margin-left: 0.5rem;
        margin-top: 0.25rem;
        background-image: url('data:image/svg+xml,%3Csvg%20width%3D%2216%22%20height%3D%2216%22%20viewBox%3D%220%200%2024%2024%22%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%3E%3Cpath%20fill%3D%22currentColor%22%20d%3D%22m12.11%2015.39-3.88%203.88a2.52%202.52%200%200%201-3.5%200%202.47%202.47%200%200%201%200-3.5l3.88-3.88a1%201%200%200%200-1.42-1.42l-3.88%203.89a4.48%204.48%200%200%200%206.33%206.33l3.89-3.88a1%201%200%201%200-1.42-1.42Zm8.58-12.08a4.49%204.49%200%200%200-6.33%200l-3.89%203.88a1%201%200%200%200%201.42%201.42l3.88-3.88a2.52%202.52%200%200%201%203.5%200%202.47%202.47%200%200%201%200%203.5l-3.88%203.88a1%201%200%201%200%201.42%201.42l3.88-3.89a4.49%204.49%200%200%200%200-6.33ZM8.83%2015.17a1%201%200%200%200%201.1.22%201%201%200%200%200%20.32-.22l4.92-4.92a1%201%200%200%200-1.42-1.42l-4.92%204.92a1%201%200%200%200%200%201.42Z%22/%3E%3C/svg%3E');
        background-repeat: no-repeat;
        background-position: center;
        background-size: 1em 1em;
        opacity: 0;
        transition: opacity 0.2s ease-in-out;
        text-decoration: none;
        vertical-align: -2px;
      }

      /* Show icon on heading hover */
      h1:hover .anchor-link,
      h2:hover .anchor-link,
      h3:hover .anchor-link,
      h4:hover .anchor-link,
      h5:hover .anchor-link,
      h6:hover .anchor-link {
        opacity: 1;
      }

      /* Show on keyboard focus */
      .anchor-link:focus {
        opacity: 1;
        outline: none;
      }
    </style>
  </Fragment>
  {/* Load search data even when sidebar is hidden */}
  <SearchDataLoader />
  <main id="eventcatalog-application" class="relative">
    {
      showHeader && (
        <div transition:persist="site-header">
          <Header showNestedSideBar={showNestedSideBar} />
        </div>
      )
    }
    <div class={`app-shell ${showNestedSideBar ? 'app-shell--with-sidebar' : 'app-shell--rail-only'}`}>
      <aside class="flex" id="eventcatalog-vertical-nav">
        <div
          id="vertical-nav-rail"
          data-collapsed="true"
          transition:persist="vertical-nav-rail"
          class="vertical-nav-rail fixed top-0 left-0 flex flex-col h-screen z-30 transition-[width] duration-200"
        >
          <a
            href={buildUrl(config.landingPage || '/')}
            aria-label="Home"
            class="nav-brand-link flex items-center gap-2.5 px-4 h-[3.75rem] border-b border-[rgb(var(--ec-sidebar-border)/0.7)] flex-shrink-0"
          >
            <img
              src={config?.logo?.src ? buildUrl('/' + config.logo.src.replace(/^\/+/, ''), true) : buildUrl('/logo.png', true)}
              alt={config?.logo?.alt || 'EventCatalog'}
              class="w-6 h-6 flex-shrink-0"
            />
            <span class="nav-brand-text text-[15px] font-semibold text-[rgb(var(--ec-page-text))] tracking-tight">
              {config?.logo?.text || config?.organizationName || 'EventCatalog'}
            </span>
          </a>

          <nav class="flex flex-col flex-1 overflow-y-auto px-3 py-4 gap-1">
            {
              topNavigationGroups.map((group, groupIndex) => (
                <Fragment>
                  {groupIndex > 0 && <hr class="rail-divider my-3 border-t border-[rgb(var(--ec-sidebar-border)/0.7)]" />}

                  {group.label && (
                    <div class="rail-section-label px-3 pb-1 text-[0.65rem] font-semibold tracking-[0.18em] uppercase text-[rgb(var(--ec-sidebar-text)/0.5)]">
                      {group.label}
                    </div>
                  )}

                  {group.items.map((item) => (
                    <a
                      id={item.id}
                      href={item.href}
                      target={item.target}
                      rel={item.rel}
                      data-role="vertical-nav-item"
                      aria-label={item.label}
                      class={`flex items-center gap-3 px-3 py-2.5 rounded-xl border text-[13px] font-medium transition-all duration-150 ${
                        item.current
                          ? 'border-[rgb(var(--ec-accent)/0.2)] bg-[rgb(var(--ec-page-bg)/0.88)] text-[rgb(var(--ec-accent))] shadow-sm'
                          : 'border-transparent text-[rgb(var(--ec-sidebar-text))] hover:border-[rgb(var(--ec-sidebar-border)/0.65)] hover:bg-[rgb(var(--ec-page-bg)/0.78)] hover:text-[rgb(var(--ec-page-text))]'
                      }`}
                      title={item.label}
                    >
                      <item.Icon className="h-4 w-4 flex-shrink-0" aria-hidden="true" />
                      <span class="nav-item-label">{item.label}</span>
                    </a>
                  ))}
                </Fragment>
              ))
            }

            <div class="mt-auto pt-3">
              {
                bottomNavigationGroups.map((group) => (
                  <Fragment>
                    <hr class="rail-divider mb-3 border-t border-[rgb(var(--ec-sidebar-border)/0.7)]" />

                    {group.label && (
                      <div class="rail-section-label px-3 pb-1 text-[0.65rem] font-semibold tracking-[0.18em] uppercase text-[rgb(var(--ec-sidebar-text)/0.5)]">
                        {group.label}
                      </div>
                    )}

                    {group.items.map((item) => (
                      <a
                        id={item.id}
                        href={item.href}
                        target={item.target}
                        rel={item.rel}
                        data-role="vertical-nav-item"
                        aria-label={item.label}
                        class={`flex items-center gap-3 px-3 py-2.5 rounded-xl border text-[13px] font-medium transition-all duration-150 ${
                          item.current
                            ? 'border-[rgb(var(--ec-accent)/0.2)] bg-[rgb(var(--ec-page-bg)/0.88)] text-[rgb(var(--ec-accent))] shadow-sm'
                            : 'border-transparent text-[rgb(var(--ec-sidebar-text))] hover:border-[rgb(var(--ec-sidebar-border)/0.65)] hover:bg-[rgb(var(--ec-page-bg)/0.78)] hover:text-[rgb(var(--ec-page-text))]'
                        }`}
                        title={item.label}
                      >
                        <item.Icon className="h-4 w-4 flex-shrink-0" aria-hidden="true" />
                        <span class="nav-item-label">{item.label}</span>
                      </a>
                    ))}
                  </Fragment>
                ))
              }
            </div>
          </nav>

          <div class="border-t border-[rgb(var(--ec-sidebar-border)/0.7)] px-3 py-3 flex-shrink-0">
            <button
              id="vertical-nav-toggle"
              type="button"
              aria-label="Collapse sidebar"
              class="flex items-center gap-3 px-3 py-2.5 rounded-xl border border-transparent text-[13px] font-medium text-[rgb(var(--ec-sidebar-text))] hover:border-[rgb(var(--ec-sidebar-border)/0.65)] hover:bg-[rgb(var(--ec-page-bg)/0.78)] hover:text-[rgb(var(--ec-page-text))] transition-all duration-150 w-full"
            >
              <LucideIcons.PanelLeftClose className="h-4 w-4 flex-shrink-0 nav-collapse-icon" aria-hidden="true" />
              <span class="nav-label">Collapse</span>
            </button>
          </div>
        </div>
      </aside>
      {
        showNestedSideBar &&
          (Astro.slots.has('sidebar-content') ? (
            <aside id="sidebar" class="sidebar-panel sidebar-transition">
              <slot name="sidebar-content" />
            </aside>
          ) : (
            <SideNav id="sidebar" class={`sidebar-panel sidebar-transition`} />
          ))
      }
      <main class="content-panel sidebar-transition w-full bg-[rgb(var(--ec-page-bg))]" id="content">
        {
          Astro.slots.has('sidebar-content') ? (
            <slot />
          ) : (
            <div class={`app-content-wrapper ${reducedContentPadding ? 'app-content-wrapper--reduced-padding' : ''}`}>
              <slot />
            </div>
          )
        }
      </main>

      <!-- Create a overlay that tells people to purchase backstage plugin if they want to embed the page -->
      <div class="absolute inset-0 bg-black items-center justify-center z-50 hidden" id="embed-overlay">
        <div class="text-white text-center space-y-4">
          <div>
            <h1 class="text-2xl font-bold">EventCatalog Backstage Integration</h1>
            <p class="text-md text-red-500">Missing license key for backstage integration.</p>
          </div>
          <div>
            <p class="text-sm text-gray-500">Please configure the backstage plugin to embed this page into Backstage.</p>
            <a href="https://www.eventcatalog.dev/integrations/backstage" class="text-blue-500 text-xs"
              >Configure backstage plugin &rarr;</a
            >
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<ClientRouter />
<script
  define:vars={{
    clientNavigationItems,
    canPageBeEmbedded,
    verticalNavAutoCollapsePaths,
  }}
>
  const VERTICAL_NAV_STORAGE_KEY = 'eventcatalog-vertical-nav-collapsed';
  const ACTIVE_NAV_CLASSES = [
    'border-[rgb(var(--ec-accent)/0.2)]',
    'bg-[rgb(var(--ec-page-bg)/0.88)]',
    'text-[rgb(var(--ec-accent))]',
    'shadow-sm',
  ];
  const INACTIVE_NAV_CLASSES = [
    'border-transparent',
    'text-[rgb(var(--ec-sidebar-text))]',
    'hover:border-[rgb(var(--ec-sidebar-border)/0.65)]',
    'hover:bg-[rgb(var(--ec-page-bg)/0.78)]',
    'hover:text-[rgb(var(--ec-page-text))]',
  ];

  const isNavItemCurrent = (item, pathname) => {
    const matchId = item?.matchId || item?.id;

    if (matchId === '/') {
      const targetPath = item?.href ? new URL(item.href, window.location.origin).pathname : '/';
      return (
        pathname === targetPath ||
        (pathname.includes('/docs') && !pathname.includes('/docs/custom')) ||
        pathname.includes('/architecture/') ||
        pathname.includes('/visualiser') ||
        (pathname.includes('/schemas') && !pathname.includes('/schemas/explorer') && !pathname.includes('/schemas/fields'))
      );
    }

    if (matchId === '/schemas/explorer') {
      return pathname.includes('/schemas/explorer') && !pathname.includes('/schemas/fields');
    }

    if (matchId === '/schemas/fields') {
      return pathname.includes('/schemas/fields');
    }

    if (matchId === '/discover') {
      return pathname.endsWith('/discover') || pathname.includes('/discover/');
    }

    if (matchId === '/studio') {
      return pathname.includes('/studio');
    }

    if (matchId === '/docs/custom') {
      return pathname.includes('/docs/custom');
    }

    if (matchId === '/settings/general') {
      return pathname.includes('/settings');
    }

    const matches = Array.isArray(item?.match) ? item.match : item?.match ? [item.match] : [];
    if (matches.length > 0) {
      return matches.some((match) => {
        if (/^https?:\/\//.test(match)) return false;

        return pathname === match || pathname.startsWith(match);
      });
    }

    if (item?.href) {
      if (/^https?:\/\//.test(item.href)) return false;

      const targetPath = new URL(item.href, window.location.origin).pathname;
      return pathname === targetPath;
    }

    return false;
  };

  const syncNavItemStates = () => {
    const pathname = window.location.pathname;
    const navItems = document.querySelectorAll('[data-role="vertical-nav-item"]');

    navItems.forEach((item) => {
      const id = item.getAttribute('id');
      const navigationItem = clientNavigationItems.find((navItem) => navItem.id === id);
      const isCurrent = navigationItem ? isNavItemCurrent(navigationItem, pathname) : false;

      if (isCurrent) {
        item.classList.remove(...INACTIVE_NAV_CLASSES);
        item.classList.add(...ACTIVE_NAV_CLASSES);
      } else {
        item.classList.remove(...ACTIVE_NAV_CLASSES);
        item.classList.add(...INACTIVE_NAV_CLASSES);
      }
    });
  };

  const routeShouldAutoCollapseVerticalNav = (pathname) =>
    verticalNavAutoCollapsePaths.some((path) => pathname === path || pathname.startsWith(`${path}/`));

  const persistVerticalNavCollapsedState = (collapsed) => {
    try {
      localStorage.setItem(VERTICAL_NAV_STORAGE_KEY, String(collapsed));
    } catch (error) {}
  };

  const getPersistedVerticalNavCollapsedState = () => {
    if (routeShouldAutoCollapseVerticalNav(window.location.pathname)) {
      persistVerticalNavCollapsedState(true);
      return true;
    }

    try {
      const savedState = localStorage.getItem(VERTICAL_NAV_STORAGE_KEY);
      return savedState === null ? true : savedState === 'true';
    } catch (error) {
      return true;
    }
  };

  const applyPersistedVerticalNavState = () => {
    const isCollapsed = getPersistedVerticalNavCollapsedState();
    document.documentElement.setAttribute('data-vertical-nav-collapsed', isCollapsed ? 'true' : 'false');

    const verticalNavRail = document.getElementById('vertical-nav-rail');
    if (verticalNavRail) {
      verticalNavRail.setAttribute('data-collapsed', isCollapsed ? 'true' : 'false');
    }
  };

  // Apply immediately when this script executes so transitions don't briefly re-open the rail.
  applyPersistedVerticalNavState();

  // Re-apply around Astro view transitions because the incoming document can momentarily drop the root attribute.
  document.addEventListener('astro:before-preparation', applyPersistedVerticalNavState);
  document.addEventListener('astro:after-swap', applyPersistedVerticalNavState);

  // Listen for Astro transititions
  document.addEventListener('astro:page-load', () => {
    applyPersistedVerticalNavState();
    document.dispatchEvent(new CustomEvent('contentLoaded'));
  });

  // Listen for DOM loaded
  document.addEventListener('DOMContentLoaded', () => {
    applyPersistedVerticalNavState();
    document.dispatchEvent(new CustomEvent('contentLoaded'));
  });

  document.addEventListener('contentLoaded', () => {
    // Users can add ?embed=true to the URL to hide the navigation
    const urlSearchParams = new URLSearchParams(window.location.search);
    const params = Object.fromEntries(urlSearchParams.entries());
    const embeded = params.embed === 'true' ? true : false;
    const content = document.getElementById('content');
    const shell = document.querySelector('.app-shell');
    const app = document.getElementById('eventcatalog-application');
    const verticalNavRail = document.getElementById('vertical-nav-rail');
    const verticalNavToggle = document.getElementById('vertical-nav-toggle');
    const navToggleLabel = verticalNavToggle?.querySelector('.nav-label');
    const collapseIcon = verticalNavToggle?.querySelector('.nav-collapse-icon');

    const setVerticalNavCollapsedState = (collapsed) => {
      if (!app || !verticalNavRail || !verticalNavToggle || !navToggleLabel) return;
      const railTextElements = verticalNavRail.querySelectorAll(
        '.nav-brand-text, .nav-item-label, .rail-section-label, .nav-count-pill, .nav-label'
      );

      document.documentElement.setAttribute('data-vertical-nav-collapsed', collapsed ? 'true' : 'false');
      verticalNavRail.setAttribute('data-collapsed', collapsed ? 'true' : 'false');
      verticalNavToggle.setAttribute('aria-label', collapsed ? 'Expand sidebar' : 'Collapse sidebar');
      verticalNavToggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
      navToggleLabel.textContent = collapsed ? 'Expand' : 'Collapse';
      railTextElements.forEach((element) => {
        if (collapsed) {
          element.setAttribute('hidden', '');
        } else {
          element.removeAttribute('hidden');
        }
      });

      if (collapseIcon) {
        collapseIcon.setAttribute('title', collapsed ? 'Expand sidebar' : 'Collapse sidebar');
      }
    };

    if (embeded && !canPageBeEmbedded) {
      const overlay = document.getElementById('embed-overlay');
      overlay.style.display = 'flex';
      return;
    }

    if (embeded) {
      const elementsToHide = [
        'eventcatalog-vertical-nav',
        'eventcatalog-header',
        'eventcatalog-header-spacer',
        'visualiser-footer',
        // /discover page elements
        'discover-collection-tabs',
        'discover-title',
      ];

      elementsToHide.forEach((id) => {
        const element = document.getElementById(id);
        if (element) element.style.display = 'none';
      });

      document.body.style.overflow = '';
      app.style.overflow = '';
      if (shell) shell.style.marginLeft = '0';
      return;
    }

    if (shell) {
      shell.style.marginLeft = '';
    }

    setVerticalNavCollapsedState(getPersistedVerticalNavCollapsedState());

    syncNavItemStates();

    if (verticalNavToggle) {
      verticalNavToggle.onclick = () => {
        const isCollapsed = verticalNavRail?.getAttribute('data-collapsed') === 'true';
        const nextState = !isCollapsed;

        setVerticalNavCollapsedState(nextState);
        persistVerticalNavCollapsedState(nextState);
      };
    }
  });
</script>
