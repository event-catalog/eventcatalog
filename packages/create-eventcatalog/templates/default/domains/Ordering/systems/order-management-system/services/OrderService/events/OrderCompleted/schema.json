{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrderCompleted",
  "description": "Published when an order has been fulfilled and completed",
  "type": "object",
  "properties": {
    "orderId": {
      "type": "string",
      "format": "uuid"
    },
    "customerId": {
      "type": "string",
      "format": "uuid"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["orderId", "customerId", "completedAt"]
}
