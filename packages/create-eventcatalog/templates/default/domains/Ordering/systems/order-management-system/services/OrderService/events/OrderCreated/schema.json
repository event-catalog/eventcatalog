{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrderCreated",
  "description": "Published when a new order has been created",
  "type": "object",
  "properties": {
    "orderId": {
      "type": "string",
      "format": "uuid"
    },
    "customerId": {
      "type": "string",
      "format": "uuid"
    },
    "total": {
      "type": "integer",
      "description": "Order total in minor units (e.g. cents)"
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["orderId", "customerId", "total", "currency", "createdAt"]
}
